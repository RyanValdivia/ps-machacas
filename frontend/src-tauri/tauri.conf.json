{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RegistraMe",
  "version": "0.1.0",
  "identifier": "com.registrame.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RegistraMe",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": true,
        "center": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://localhost:8000 http://127.0.0.1:8000; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000; img-src 'self' asset: http://localhost:8000 http://127.0.0.1:8000 data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries": "."
    }
  },
  "plugins": {}
}